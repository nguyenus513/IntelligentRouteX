<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".RouteFoodApp"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.RouteFood">
        <activity
            android:name=".feature.driver.compose.DriverShellActivity"
            android:exported="false"
            android:theme="@style/Theme.RouteFood" />
        <activity
            android:name=".driver.DriverDemoActivity"
            android:exported="false"
            android:theme="@style/Theme.RouteFood" />
        <activity
            android:name=".compose.MainActivity"
            android:exported="false"
            android:theme="@style/Theme.RouteFood" />
        <activity
            android:name=".feature.user.tracking.UserTrackingActivity"
            android:exported="false" />
        <activity
            android:name=".feature.user.checkout.CheckoutActivity"
            android:exported="false" />
        <activity
            android:name=".feature.user.cart.CartActivity"
            android:exported="false" />
        <activity
            android:name=".feature.user.restaurant.RestaurantDetailActivity"
            android:exported="false" />
        <activity
            android:name=".feature.driver.navigation.DriverNavigationActivity"
            android:exported="false" />
        <activity
            android:name=".feature.driver.DriverMainActivity"
            android:exported="false" />
        <activity
            android:name=".feature.user.UserMainActivity"
            android:exported="false" />
        <activity
            android:name=".feature.auth.SelectRoleActivity"
            android:exported="false" />
        <activity
            android:name=".feature.auth.RegisterActivity"
            android:exported="false" />
        <activity
            android:name=".feature.auth.LoginActivity"
            android:exported="false" />
        <activity
            android:name=".feature.splash.SplashActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>
