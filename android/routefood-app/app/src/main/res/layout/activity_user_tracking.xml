<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/route_background"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Theo dõi đơn"
        android:textColor="@color/route_text_primary"
        android:textSize="24sp"
        android:textStyle="bold" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_weight="2">

        <com.routefood.app.core.map.DemoMapView
            android:id="@+id/userTrackingMapView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <TextView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_primary_cta"
            android:gravity="center"
            android:text="▣"
            android:textColor="@color/route_button_primary_text"
            android:textSize="24sp" />
    </FrameLayout>

    <TextView
        android:id="@+id/trackingStatusText"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_weight="1"
        android:background="@drawable/bg_bottom_sheet"
        android:gravity="center"
        android:padding="20dp"
        android:textColor="@color/route_text_primary"
        android:textSize="18sp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_floating_bar"
        android:gravity="center_vertical"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:text="Tài xế Minh • ⭐ 4.9 • Gọi / Chat"
        android:textColor="@color/route_text_primary"
        android:textStyle="bold" />
</LinearLayout>
