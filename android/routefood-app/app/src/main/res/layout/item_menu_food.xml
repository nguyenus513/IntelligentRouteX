<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="@color/route_surface"
    app:cardCornerRadius="20dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/route_glass_border"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/menuNameText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/route_text_primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/menuDescriptionText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:lineSpacingExtra="2dp"
                android:maxLines="2"
                android:textColor="@color/route_text_secondary"
                android:textSize="13sp" />
        </LinearLayout>

        <FrameLayout
            android:layout_width="82dp"
            android:layout_height="82dp"
            android:layout_marginStart="12dp"
            android:background="@drawable/bg_noir_photo_food">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/addMenuItemButton"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginBottom="-1dp"
                android:minWidth="38dp"
                android:minHeight="38dp"
                android:padding="0dp"
                android:text="+"
                android:textSize="17sp" />
        </FrameLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>