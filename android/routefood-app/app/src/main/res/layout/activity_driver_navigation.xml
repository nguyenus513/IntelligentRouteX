<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/route_background"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:id="@+id/navigationTitleText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Driver navigation"
        android:textColor="@color/route_text_primary"
        android:textSize="28sp"
        android:textStyle="bold" />

    <com.routefood.app.core.map.DemoMapView
        android:id="@+id/driverNavigationMapView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_weight="1" />

    <TextView
        android:id="@+id/navigationInstructionText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_card"
        android:padding="16dp"
        android:text="Follow the route to pickup."
        android:textColor="@color/route_text_primary"
        android:textSize="16sp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/nextNavigationStepButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="16dp"
        android:text="Arrived pickup" />
</LinearLayout>
