<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/route_background">

    <com.routefood.app.core.map.LeafletMapView android:id="@+id/driverNavigationMapView" android:layout_width="match_parent" android:layout_height="match_parent" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="18dp"
        android:layout_marginTop="42dp"
        android:layout_marginEnd="18dp"
        android:orientation="vertical">

        <TextView android:id="@+id/navigationTitleText" android:layout_width="match_parent" android:layout_height="56dp" android:background="@drawable/bg_floating_bar" android:gravity="center_vertical" android:paddingStart="18dp" android:paddingEnd="18dp" android:text="Batch route • P1 next • 8 min" android:textColor="@color/route_text_primary" android:textSize="16sp" android:textStyle="bold" />
        <TextView android:layout_width="match_parent" android:layout_height="40dp" android:layout_marginTop="8dp" android:background="@drawable/bg_pill" android:gravity="center" android:text="SEQUENCE  P1 → P2 → D1 → D2" android:textColor="@color/route_text_primary" android:textSize="11sp" android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_bottom_sheet"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingTop="18dp"
        android:paddingEnd="18dp"
        android:paddingBottom="20dp">

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:letterSpacing="0.1" android:text="BATCH DELIVERY • 2 ORDERS" android:textColor="@color/route_success" android:textSize="10sp" android:textStyle="bold" />
        <TextView android:id="@+id/navigationInstructionText" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:lineSpacingExtra="4dp" android:text="Stop P1: Aura Kitchen\nOrder N-4821 • 3 items • verify bag seal\nNext: P2 Kuro Sushi, 600m" android:textColor="@color/route_text_primary" android:textSize="18sp" android:textStyle="bold" />
        <TextView android:layout_width="match_parent" android:layout_height="44dp" android:layout_marginTop="12dp" android:background="@drawable/bg_search" android:gravity="center_vertical" android:paddingStart="14dp" android:paddingEnd="14dp" android:text="Batch logic: same corridor, +$4.60, saves 11 min" android:textColor="@color/route_text_secondary" android:textSize="13sp" android:textStyle="bold" />

        <LinearLayout android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginTop="14dp" android:orientation="horizontal">
            <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_marginEnd="8dp" android:layout_weight="1" android:background="@drawable/bg_search" android:gravity="center" android:text="CALL" android:textColor="@color/route_text_primary" android:textSize="11sp" android:textStyle="bold" />
            <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_marginEnd="8dp" android:layout_weight="1" android:background="@drawable/bg_search" android:gravity="center" android:text="CHAT" android:textColor="@color/route_text_primary" android:textSize="11sp" android:textStyle="bold" />
            <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="@drawable/bg_search" android:gravity="center" android:text="ISSUE" android:textColor="@color/route_text_primary" android:textSize="11sp" android:textStyle="bold" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton android:id="@+id/nextNavigationStepButton" android:layout_width="match_parent" android:layout_height="56dp" android:layout_marginTop="14dp" android:text="ARRIVED AT P1" />
    </LinearLayout>
</FrameLayout>