<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="16dp"
    android:background="@drawable/bg_card">

    <!-- Status Indicator -->
    <FrameLayout
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:gravity="center">

        <View
            android:id="@+id/statusDot"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:background="@drawable/circle_background"/>

        <View
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:background="@drawable/circle_border"/>
    </FrameLayout>

    <!-- Order Details -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="12dp"
        android:layout_gravity="center_vertical">

        <TextView
            android:id="@+id/orderNumberText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="#ORD123"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/route_text_primary"/>

        <TextView
            android:id="@+id/dateText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Jan 15, 2025"
            android:textSize="12sp"
            android:textColor="@color/route_text_muted"/>

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="In Transit"
            android:textSize="13sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- Price & Arrow -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="end"
        android:layout_gravity="center_vertical">

        <TextView
            android:id="@+id/priceText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="VND 150K"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/route_text_primary"/>

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginTop="4dp"
            android:src="@drawable/ic_arrow_right"
            android:tint="@color/route_text_muted"
            android:contentDescription="Details"/>
    </LinearLayout>

</LinearLayout>
