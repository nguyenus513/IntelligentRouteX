{
  "name": "irx-control-tower-playground",
  "private": true,
  "version": "1.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5173",
    "typecheck": "tsc --noEmit",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0 --port 5173",
    "test:web": "playwright test",
    "test:web:smoke": "playwright test smoke.spec.ts",
    "test:web:live": "playwright test live.spec.ts map-tracking.spec.ts demo.spec.ts",
    "test:web:report": "playwright show-report"
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "leaflet": "^1.9.4",
    "lucide-react": "latest",
    "react": "latest",
    "react-dom": "latest",
    "typescript": "latest",
    "vite": "latest"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/leaflet": "^1.9.21",
    "@types/react": "latest",
    "@types/react-dom": "latest"
  }
}
